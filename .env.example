# ─── Required ─────────────────────────────────────────────────────────────────
DATABASE_PUBLIC_URL=postgresql://user:password@localhost:5432/meetingservice
SESSION_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# ─── Admin account (seeded on first start) ────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_before_deploying

# ─── Email (Resend) — optional, silently skipped if not set ──────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Stripe — optional, disables card payments if not set ────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── App URL (used in email links) ───────────────────────────────────────────
APP_URL=http://localhost:3000

# ─── CORS — comma-separated allowed origins (defaults to localhost:3000) ──────
# ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ─── TURN server — recommended for users behind NAT/firewalls ─────────────────
# Without TURN, ~15% of users (corporate NAT, VPN) won't be able to connect.
# Options: self-hosted coturn, Twilio TURN, Cloudflare TURN, or Xirsys
# TURN_URLS=turn:your-turn-server.com:3478
# TURN_USERNAME=your_turn_username
# TURN_CREDENTIAL=your_turn_password

# ─── Default API key for admin (generated randomly if not set) ────────────────
# DEFAULT_API_KEY=mk_your_custom_key_here

# ─── Crypto (USDC deposits) — optional ───────────────────────────────────────
# CRYPTO_MNEMONIC=your twelve word mnemonic phrase here for hd wallet derivation

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
